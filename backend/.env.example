# Key from Google AI Studio (https://aistudio.google.com/apikey)
# If left empty the system runs in fallback (rule-based) mode.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Optional: database file path
# WATTRA_DB=/data/wattra.db

# Semantic memory (S2-5): on by default, but only activates when a
# GEMINI_API_KEY is set AND chromadb is installed (requirements-semantic.txt).
# WATTRA_SEMANTIC_MEMORY=1
# WATTRA_CHROMA_PATH=/data/chroma
# GEMINI_EMBED_MODEL=gemini-embedding-001
